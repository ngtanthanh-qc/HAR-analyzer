]],[null,[[[[null,[null,0,\\\"Multiple Use\\\",[[0,12,[[null,null,null,null,2]]]]]]]],[[[null,[null,0,\\\"Only one per file\\\"]]]],[[[null,[null,0,\\\"Can be used many times in one file\\\"]]]]]]],true]],[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[]],[null,[null,3,\\\"Summary Checklist\\\"]],[null,null,null,null,null,null,null,null,null,null,null,[[[[[null,[null,0,\\\"Don't try to put {% block %} inside an included file to override it; Django will ignore it or get confused by the scope.\\\",[[0,5,[[null,null,null,null,2]]],[17,28,[[null,null,null,null,3]]]]]]]],[[[null,[null,0,\\\"Do use {{ variable|default:\\\\\\\"...\\\\\\\" }} inside your included file to create \\\\\\\"slots.\\\\\\\"\\\",[[0,2,[[null,null,null,null,2]]],[7,35,[[null,null,null,null,3]]]]]]]],[[[null,[null,0,\\\"Do use the with keyword to inject the specific data you want to display.\\\",[[0,2,[[null,null,null,null,2]]],[11,15,[[null,null,null,null,3]]]]]]]]]]],[null,[null,0,\\\"Would you like to see how\\\"]]]]],null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,false,[[[[1004,\\\"Longer\\\",5,null,[null,\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/expand/default/24px.svg\\\",\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/expand/default/24px.svg\\\",true]],[1005,\\\"Shorter\\\",6,null,[null,\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/compress/default/24px.svg\\\",\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/compress/default/24px.svg\\\",true]],[1001,\\\"Try again\\\",1,null,[null,\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/refresh/default/24px.svg\\\",\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/refresh/default/24px.svg\\\",true]]]]],null,1,0]\"]]\n9505\n[[\"wrb.fr\",null,\"[null,[\\\"c_435cd3107607b66c\\\",\\\"r_9ed7e713564c1233\\\"],null,null,[[\\\"rc_46cf7b126b730b83\\\",[\\\"In the standard Django Template Language (DTL), the `{% include %}` tag is designed for **reusability**, not **extensibility**. This means that unlike `{% extends %}`, you cannot use `{% block %}` tags inside an included file and expect to \\\\\\\"override\\\\\\\" them from the parent template.\\\\n\\\\nHowever, you can achieve \\\\\\\"overriding\\\\\\\" behavior using one of the three methods below, depending on how much control you need.\\\\n\\\\n---\\\\n\\\\n### Method 1: The \\\\\\\"Variable\\\\\\\" Approach (Recommended)\\\\nThis is the standard way to \\\\\\\"override\\\\\\\" content in an included template. You design the included template to look for a variable, and you pass that variable in when you include it.\\\\n\\\\n**1. The \\\\\\\"Reusable\\\\\\\" Template (`_card.html`):**\\\\n```html\\\\n\\\\u003cdiv class\\\\u003d\\\\\\\"card\\\\\\\"\\\\u003e\\\\n    \\\\u003cdiv class\\\\u003d\\\\\\\"card-header\\\\\\\"\\\\u003e\\\\n        {{ title|default:\\\\\\\"Default Header\\\\\\\" }}\\\\n    \\\\u003c/div\\\\u003e\\\\n    \\\\u003cdiv class\\\\u003d\\\\\\\"card-body\\\\\\\"\\\\u003e\\\\n        {{ content }}\\\\n    \\\\u003c/div\\\\u003e\\\\n\\\\u003c/div\\\\u003e\\\\n```\\\\n\\\\n**2. The Main Template:**\\\\n```html\\\\n{% include \\\\\\\"_card.html\\\\\\\" with title\\\\u003d\\\\\\\"My Special Title\\\\\\\" content\\\\u003d\\\\\\\"This is the overridden body.\\\\\\\" %}\\\\n```\\\\n\\\\n---\\\\n\\\\n### Method 2: The \\\\\\\"Partial Component\\\\\\\" Approach\\\\nIf your \\\\\\\"override\\\\\\\" involves complex HTML rather than just a string of text, you can pass a rendered block or another template as a variable.\\\\n\\\\n**1. The Main Template:**\\\\n```html\\\\n{% include \\\\\\\"_card.html\\\\\\\" with title\\\\u003d\\\\\\\"Complex Card\\\\\\\" content\\\\u003dspecial_html_variable %}\\\\n```\\\\n*Note: This requires you to pass the HTML from your view or a custom template tag.*\\\\n\\\\n---\\\\n\\\\n### Method 3: Using `django-overextends` or Custom Tags\\\\nIf you find yourself wishing `include` worked exactly like `extends` (where you can define blocks), the native DTL doesn't support it. However, many developers use **Jinja2** (which Django supports) because it allows for **Macros**, which are much more flexible for this specific use case.\\\\n\\\\n#### Comparison of Include vs. Extend\\\\n\\\\n| Feature | `{% extends %}` | `{% include %}` |\\\\n| :--- | :--- | :--- |\\\\n| **Relationship** | Child-to-Parent (Vertical) | Parent-to-Fragment (Horizontal) |\\\\n| **Overriding** | Uses `{% block %}` | Uses `with` variables |\\\\n| **Best For** | Site-wide layouts | Reusable UI components (buttons, cards) |\\\\n| **Multiple Use** | Only one per file | Can be used many times in one file |\\\\n\\\\n---\\\\n\\\\n### Summary Checklist\\\\n* **Don't** try to put `{% block %}` inside an included file to override it; Django will ignore it or get confused by the scope.\\\\n* **Do** use `{{ variable|default:\\\\\\\"...\\\\\\\" }}` inside your included file to create \\\\\\\"slots.\\\\\\\"\\\\n* **Do** use the `with` keyword to inject the specific data you want to display.\\\\n\\\\nWould you like to see how to handle this if you need to pass large chunks of HTML instead of just simple text strings?\\\"],null,null,null,null,true,null,[1],\\\"en\\\",null,null,[null,null,null,null,null,null,[0],[]],null,null,true,null,null,null,null,null,[false],null,false,[],null,null,null,[]]],[\\\"California, USA\\\",\\\"SWML_DESCRIPTION_FROM_YOUR_INTERNET_ADDRESS\\\",false,null,\\\"//www.google.com/maps/vt/data\\\\u003d7KRMCtKULmfFRNc3txH4F9VXgNSb6CwFMH3PVINz9PlUGdvRefP07Ws23u29o0ckUnlZKkL7FSkcM2-yc6OQriBOChui0d-GN9f1CsaShmquHeBPYmLVdqoFfzWrWKsis9lSq8B_deKaHIp1MVA8HX1vF6rOpIAmolKLp32GjEodsRCWDwaFvdop7A\\\"],null,null,\\\"US\\\",null,null,null,null,null,false,null,null,null,null,\\\"en\\\",null,null,null,true,[null,[false,false],[false]],null,[[[[null,[null,0,\\\"In the standard Django Template Language (DTL), the {% include %} tag is designed for reusability, not extensibility. This means that unlike {% extends %}, you cannot use {% block %} tags inside an included file and expect to \\\\\\\"override\\\\\\\" them from the parent template.\\\",[[52,65,[[null,null,null,null,3]]],[86,97,[[null,null,null,null,2]]],[103,116,[[null,null,null,null,2]]],[141,154,[[null,null,null,null,3]]],[171,182,[[null,null,null,null,3]]]]]],[null,[null,0,\\\"However, you can achieve \\\\\\\"overriding\\\\\\\" behavior using one of the three methods below, depending on how much control you need.\\\"]],[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[]],[null,[null,3,\\\"Method 1: The \\\\\\\"Variable\\\\\\\" Approach (Recommended)\\\"]],[null,[null,0,\\\"This is the standard way to \\\\\\\"override\\\\\\\" content in an included template. You design the included template to look for a variable, and you pass that variable in when you include it.\\\"]],[null,[null,0,\\\"1. The \\\\\\\"Reusable\\\\\\\" Template (_card.html):\\\",[[28,38,[[null,null,null,null,3]]],[0,40,[[null,null,null,null,2]]]]]],[null,null,null,[\\\"\\\\u003cdiv class\\\\u003d\\\\\\\"card\\\\\\\"\\\\u003e\\\\n    \\\\u003cdiv class\\\\u003d\\\\\\\"card-header\\\\\\\"\\\\u003e\\\\n        {{ title|default:\\\\\\\"Default Header\\\\\\\" }}\\\\n    \\\\u003c/div\\\\u003e\\\\n    \\\\u003cdiv class\\\\u003d\\\\\\\"card-body\\\\\\\"\\\\u003e\\\\n        {{ content }}\\\\n    \\\\u003c/div\\\\u003e\\\\n\\\\u003c/div\\\\u003e\\\\n\\\",\\\"html\\\"]],[null,[null,0,\\\"2. The Main Template:\\\",[[0,21,[[null,null,null,null,2]]]]]],[null,null,null,[\\\"{% include \\\\\\\"_card.html\\\\\\\" with title\\\\u003d\\\\\\\"My Special Title\\\\\\\" content\\\\u003d\\\\\\\"This is the overridden body.\\\\\\\" %}\\\\n\\\",\\\"html\\\"]],[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[]],[null,[null,3,\\\"Method 2: The \\\\\\\"Partial Component\\\\\\\" Approach\\\"]],[null,[null,0,\\\"If your \\\\\\\"override\\\\\\\" involves complex HTML rather than just a string of text, you can pass a rendered block or another template as a variable.\\\"]],[null,[null,0,\\\"1. The Main Template:\\\",[[0,21,[[null,null,null,null,2]]]]]],[null,null,null,[\\\"{% include \\\\\\\"_card.html\\\\\\\" with title\\\\u003d\\\\\\\"Complex Card\\\\\\\" content\\\\u003dspecial_html_variable %}\\\\n\\\",\\\"html\\\"]],[null,[null,0,\\\"Note: This requires you to pass the HTML from your view or a custom template tag.\\\",[[0,81,[[null,null,null,null,1]]]]]],[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[]],[null,[null,3,\\\"Method 3: Using django-overextends or Custom Tags\\\",[[16,34,[[null,null,null,null,3]]]]]],[null,[null,0,\\\"If you find yourself wishing include worked exactly like extends (where you can define blocks), the native DTL doesn't support it. However, many developers use Jinja2 (which Django supports) because it allows for Macros, which are much more flexible for this specific use case.\\\",[[29,36,[[null,null,null,null,3]]],[57,64,[[null,null,null,null,3]]],[160,166,[[null,null,null,null,2]]],[213,219,[[null,null,null,null,2]]]]]],[null,[null,4,\\\"Comparison of Include vs. Extend\\\"]],[null,null,null,null,null,null,null,null,null,null,[[[null,[[[[null,[null,0,\\\"Feature\\\"]]]],[[[null,[null,0,\\\"{% extends %}\\\",[[0,13,[[null,null,null,null,3]]]]]]]],[[[null,[null,0,\\\"{% include %}\\\",[[0,13,[[null,null,null,null,3]]]]]]]]]],[null,[[[[null,[null,0,\\\"Relationship\\\",[[0,12,[[null,null,null,null,2]]]]]]]],[[[null,[null,0,\\\"Child-to-Parent (Vertical)\\\"]]]],[[[null,[null,0,\\\"Parent-to-Fragment (Horizontal)\\\"]]]]]],[null,[[[[null,[null,0,\\\"Overriding\\\",[[0,10,[[null,null,null,null,2]]]]]]]],[[[null,[null,0,\\\"Uses {% block %}\\\",[[5,16,[[null,null,null,null,3]]]]]]]],[[[null,[null,0,\\\"Uses with variables\\\",[[5,9,[[null,null,null,null,3]]]]]]]]]],[null,[[[[null,[null,0,\\\"Best For\\\",[[0,8,[[null,null,null,null,2]]]]]]]],[[[null,[null,0,\\\"Site-wide layouts\\\"]]]],[[[null,[null,0,\\\"Reusable UI components (buttons, cards)\\\"]]]]]],[null,[[[[null,[null,0,\\\"Multiple Use\\\",[[0,12,[[null,null,null,null,2]]]]]]]],[[[null,[null,0,\\\"Only one per file\\\"]]]],[[[null,[null,0,\\\"Can be used many times in one file\\\"]]]]]]],true]],[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[]],[null,[null,3,\\\"Summary Checklist\\\"]],[null,null,null,null,null,null,null,null,null,null,null,[[[[[null,[null,0,\\\"Don't try to put {% block %} inside an included file to override it; Django will ignore it or get confused by the scope.\\\",[[0,5,[[null,null,null,null,2]]],[17,28,[[null,null,null,null,3]]]]]]]],[[[null,[null,0,\\\"Do use {{ variable|default:\\\\\\\"...\\\\\\\" }} inside your included file to create \\\\\\\"slots.\\\\\\\"\\\",[[0,2,[[null,null,null,null,2]]],[7,35,[[null,null,null,null,3]]]]]]]],[[[null,[null,0,\\\"Do use the with keyword to inject the specific data you want to display.\\\",[[0,2,[[null,null,null,null,2]]],[11,15,[[null,null,null,null,3]]]]]]]]]]],[null,[null,0,\\\"Would you like to see how to handle this if you need to pass large chunks of HTML instead of just simple text strings?\\\"]]]]],null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,false,[[[[1004,\\\"Longer\\\",5,null,[null,\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/expand/default/24px.svg\\\",\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/expand/default/24px.svg\\\",true]],[1005,\\\"Shorter\\\",6,null,[null,\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/compress/default/24px.svg\\\",\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/compress/default/24px.svg\\\",true]],[1001,\\\"Try again\\\",1,null,[null,\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/refresh/default/24px.svg\\\",\\\"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/refresh/default/24px.svg\\\",true]]]]],null,1,0]\"]]\n9815\n[[\"wrb.fr\",null,\"[null,[\\\"c_435cd3107607b66c\\\",\\\"r_9ed7e713564c1233\\\"],null,null,[[\\\"rc_46cf7b126b730b83\\\",[\\\"In the standard Django Template Language (DTL), the `{% include %}` tag is designed for **reusability**, not **extensibility**. This means that unlike `{% extends %}`, you cannot use `{% block %}` tags inside an included file and expect to \\\\\\\"override\\\\\\\" them from the parent template.\\\\n\\\\nHowever, you can achieve \\\\\\\"overriding\\\\\\\" behavior using one of the three methods below, depending on how much control you need.\\\\n\\\\n---\\\\n\\\\n### Method 1: The \\\\\\\"Variable\\\\\\\" Approach (Recommended)\\\\nThis is the standard way to \\\\\\\"override\\\\\\\" content in an included template. You design the included template to look for a variable, and you pass that variable in when you include it.\\\\n\\\\n**1. The \\\\\\\"Reusable\\\\\\\" Template (`_card.html`):**\\\\n```html\\\\n\\\\u003cdiv class\\\\u003d\\\\\\\"card\\\\\\\"\\\\u003e\\\\n    \\\\u003cdiv class\\\\u003d\\\\\\\"card-header\\\\\\\"\\\\u003e\\\\n        {{ title|default:\\\\\\\"Default Header\\\\\\\" }}\\\\n    \\\\u003c/div\\\\u003e\\\\n    \\\\u003cdiv class\\\\u003d\\\\\\\"card-body\\\\\\\"\\\\u003e\\\\n        {{ content }}\\\\n    \\\\u003c/div\\\\u003e\\\\n\\\\u003c/div\\\\u003e\\\\n```\\\\n\\\\n**2. The Main Template:**\\\\n```html\\\\n{% include \\\\\\\"_card.html\\\\\\\" with title\\\\u003d\\\\\\\"My Special Title\\\\\\\" content\\\\u003d\\\\\\\"This is the overridden body.\\\\\\\" %}\\\\n```\\\\n\\\\n---\\\\n\\\\n### Method 2: The \\\\\\\"Partial Component\\\\\\\" Approach\\\\nIf your \\\\\\\"override\\\\\\\" involves complex HTML rather than just a string of text, you can pass a rendered block or another template as a variable.\\\\n\\\\n**1. The Main Template:**\\\\n```html\\\\n{% include \\\\\\\"_card.html\\\\\\\" with title\\\\u003d\\\\\\\"Complex Card\\\\\\\" content\\\\u003dspecial_html_variable %}\\\\n```\\\\n*Note: This requires you to pass the HTML from your view or a custom template tag.*\\\\n\\\\n---\\\\n\\\\n### Method 3: Using `django-overextends` or Custom Tags\\\\nIf you find yourself wishing `include` worked exactly like `extends` (where you can define blocks), the native DTL doesn't support it. However, many developers use **Jinja2** (which Django supports) because it allows for **Macros**, which are much more flexible for this specific use case.\\\\n\\\\n#### Comparison of Include vs. Extend\\\\n\\\\n| Feature | `{% extends %}` | `{% include %}` |\\\\n| :--- | :--- | :--- |\\\\n| **Relationship** | Child-to-Parent (Vertical) | Parent-to-Fragment (Horizontal) |\\\\n| **Overriding** | Uses `{% block %}` | Uses `with` variables |\\\\n| **Best For** | Site-wide layouts | Reusable UI components (buttons, cards) |\\\\n| **Multiple Use** | Only one per file | Can be used many times in one file |\\\\n\\\\n---\\\\n\\\\n### Summary Checklist\\\\n* **Don't** try to put `{% block %}` inside an included file to override it; Django will ignore it or get confused by the scope.\\\\n* **Do** use `{{ variable|default:\\\\\\\"...\\\\\\\" }}` inside your included file to create \\\\\\\"slots.\\\\\\\"\\\\n* **Do** use the `with` keyword to inject the specific data you want to display.\\\\n\\\\nWould you like to see how to handle this if you need to pass large chunks of HTML instead of just simple text strings?\\\"],[null,null,null,null,[null,null,7]],null,null,null,true,null,[2],\\\"en\\\",null,null,[null,null,null,null,null,null,[0],[]],null,null,true,null,null,null,null,null,[false],null,false,[],null,null,null,[]]],[\\\"California, USA\\\",\\\"SWML_DESCRIPTION_FROM_YOUR_INTERNET_ADDRESS\\\",false,null,\\\"//www.google.com/maps/vt/data\\\\u003d7KRMCtKULmfFRNc3txH4F9VXgNSb6CwFMH3PVINz9PlUGdvRefP07Ws23u29o0ckUnlZKkL7FSkcM2-yc6OQriBOChui0d-GN9f1CsaShmquHeBPYmLVdqoFfzWrWKsis9lSq8B_deKaHIp1MVA8HX1vF6rOpIAmolKLp32GjEodsRCWDwaFvdop7A\\\"],null,null,\\\"US\\\",null,null,null,null,null,true,null,null,null,null,\\\"en\\\",null,null,null,true,[null,[false,false],[false]],null,[[[[null,[null,0,\\\"In the standard Django Template Language (DTL), the {% include %} tag is designed for reusability, not extensibility. This means that unlike {% extends %}, you cannot use {% block %} tags inside an included file and expect to \\\\\\\"override\\\\\\\" them from the parent template.\\\",[[52,65,[[null,null,null,null,3]]],[86,97,[[null,null,null,null,2]]],[103,116,[[null,null,null,null,2]]],[141,154,[[null,null,null,null,3]]],[171,182,[[null,null,null,null,3]]]]]],[null,[null,0,\\\"However, you can achieve \\\\\\\"overriding\\\\\\\" behavior using one of the three methods below, depending on how much control you need.\\\"]],[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[]],[null,[null,3,\\\"Method 1: The \\\\\\\"Variable\\\\\\\" Approach (Recommended)\\\"]],[null,[null,0,\\\"This is the standard way to \\\\\\\"override\\\\\\\" content in an included template. You design the included template to look for a variable, and you pass that variable in when you include it.\\\"]],[null,[null,0,\\\"1. The \\\\\\\"Reusable\\\\\\\" Template (_card.html):\\\",[[28,38,[[null,null,null,null,3]]],[0,40,[[null,null,null,null,2]]]]]],[null,null,null,[\\\"\\\\u003cdiv class\\\\u003d\\\\\\\"card\\\\\\\"\\\\u003e\\\\n    \\\\u003cdiv class\\\\u003d\\\\\\\"card-header\\\\\\\"\\\\u003e\\\\n        {{ title|default:\\\\\\\"Default Header\\\\\\\" }}\\\\n    \\\\u003c/div\\\\u003e\\\\n    \\\\u003cdiv class\\\\u003d\\\\\\\"card-body\\\\\\\"\\\\u003e\\\\n        {{ content }}\\\\n    \\\\u003c/div\\\\u003e\\\\n\\\\u003c/div\\\\u003e\\\\n\\\",\\\"html\\\"]],[null,[null,0,\\\"2. The Main Template:\\\",[[0,21,[[null,null,null,null,2]]]]]],[null,null,null,[\\\"{% include \\\\\\\"_card.html\\\\\\\" with title\\\\u003d\\\\\\\"My Special Title\\\\\\\" content\\\\u003d\\\\\\\"This is the overridden body.\\\\\\\" %}\\\\n\\\",\\\"html\\\"]],[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[]],[null,[null,3,\\\"Method 2: The \\\\\\\"Partial Component\\\\\\\" Approach\\\"]],[null,[null,0,\\\"If your \\\\\\\"override\\\\\\\" involves complex HTML rather than just a string of text, you can pass a rendered block or another template as a variable.\\\"]],[null,[null,0,\\\"1. The Main Template:\\\",[[0,21,[[null,null,null,null,2]]]]]],[null,null,null,[\\\"{% include \\\\\\\"_card.html\\\\\\\" with title\\\\u003d\\\\\\\"Complex Card\\\\\\\" content\\\\u003dspecial_html_variable %}\\\\n\\\",\\\"html\\\"]],[null,[null,0,\\\"Note: This requires you to pass the HTML from your view or a custom template tag.\\\",[[0,81,[[null,null,null,null,1]]]]]],[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[]],[null,[null,3,\\\"Method 3: Using django-overextends or Custom Tags\\\",[[16,34,[[null,null,null,null,3]]]]]],[null,[null,0,\\\"If you find yourself wishing include worked exactly like extends (where you can define blocks), the native DTL doesn't support it. However, many developers use Jinja2 (which Django supports) because it allows for Macros, which are much more flexible for this specific use case.\\\",[[29,36,[[null,null,null,null,3]]],[57,64,[[null,null,null,null,3]]],[160,166,[[null,null,null,null,2]]],[213,219,[[null,null,null,null,2]]]]]],[null,[null,4,\\\"Comparison of Include vs. Extend\\\"]],[null,null,null,null,null,null,null,null,null,null,[[[null,[[[[null,[null,0,\\\"Feature\\\"]]]],[[[null,[null,0,\\\"{% extends %}\\\",[[0,13,[[null,null,null,null,3]]]]]]]],[[[null,[null,0,\\\"{% include %}\\\",[[0,13,[[null,null,null,null,3]]]]]]]]]],[null,[[[[null,[null,0,\\\"Relationship\\\",[[0,12,[[null,null,null,null,2]]]]]]]],[[[null,[null,0,\\\"Child-to-Parent (Vertical)\\\"]]]],[[[null,[null,0,\\\"Parent-to-Fragment (Horizontal)\\\"]]]]]],[